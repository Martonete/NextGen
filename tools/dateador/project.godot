; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be edited via code.

config_version=5

[application]

config/name="AO Dateador"
run/main_scene="res://Scenes/Main.tscn"
config/features=PackedStringArray("4.3", "C#")

[display]

window/size/viewport_width=1400
window/size/viewport_height=820
window/size/mode=2

[dotnet]

project/assembly_name="AODateador"

[rendering]

renderer/rendering_method="gl_compatibility"
environment/defaults/default_clear_color=Color(0.112, 0.114, 0.128, 1)
